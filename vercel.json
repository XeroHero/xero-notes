{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "version": 2,
  "builds": [
        {
            "src": "api/app.py",
            "use": "@vercel/python"
        }
    ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
