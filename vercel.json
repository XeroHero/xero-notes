{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/api/auth/simple-signup",
      "dest": "/api/simple-auth-mongo.py"
    },
    {
      "src": "/api/auth/simple-login",
      "dest": "/api/simple-auth-mongo.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
