{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "version": 2,
  "builds": [
        {
            "src": "api/auth.js",
            "use": "@vercel/node"
        }
    ],
  "routes": [
    {
      "src": "/api/auth/simple-login",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/auth.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
